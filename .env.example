# Binance 合约 API 凭证 —— 复制为 .env 并填入 (.env 已 gitignore, 切勿提交)
#
# 获取 Key:
#   Testnet (推荐先用, 免费测试币): https://testnet.binancefuture.com  注册→生成 API Key
#   实盘: Binance → API Management → Create API
#     · 仅勾选「启用合约 / Enable Futures」, 关闭「提现 Enable Withdrawals」
#     · 绑定服务器出口 IP 白名单 (首尔 43.164.191.143)
#
# 用法: 在服务器  set -a && source .env && set +a  后运行
#       python3 -m cryptoquant.live   或   python3 -m cryptoquant.web

BINANCE_KEY=your_api_key_here
BINANCE_SECRET=your_api_secret_here
